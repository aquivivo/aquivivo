{
    "functions":  [
                      {
                          "source":  "functions",
                          "codebase":  "default",
                          "ignore":  [
                                         "node_modules",
                                         ".git",
                                         "firebase-debug.log",
                                         "firebase-debug.*.log",
                                         "*.local"
                                     ]
                      }
                  ],
    "storage":  {
                    "rules":  "firebase-storage.rules"
                },
    "firestore":  {
                      "rules":  "firestore.rules"
                  },
    "hosting":  {
                    "public":  "app",
                    "ignore":  [
                                   "firebase.json",
                                   "**/.*",
                                   "**/node_modules/**",
                                   "functions/**"
                               ],
                    "rewrites":  [
                                     {
                                         "source":  "/api/**",
                                         "function":  "api"
                                     },
                                     {
                                         "source":  "**",
                                         "destination":  "/index.html"
                                     }
                                 ]
                }
}
